# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Get this from platform.openai.com → API Keys
OPENAI_API_KEY=

# This is your PostgreSQL connection string
# When running locally with Docker: use the line below exactly
DATABASE_URL=postgresql://docmind:secret@localhost:5432/docmind

# URL where your backend runs (used by the frontend)
BACKEND_URL=http://localhost:8000